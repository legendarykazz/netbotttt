# Choose text provider: openai, openrouter, or gemini.
AI_TEXT_PROVIDER=openai

# Choose image provider: openai or gemini.
# OpenRouter is best for text/calendar generation; use OpenAI or Gemini for images.
AI_IMAGE_PROVIDER=openai

OPENAI_API_KEY=sk-your-openai-api-key
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key
GEMINI_API_KEY=your-gemini-api-key

# Text generation model used for captions, hashtags, CTAs, and calendars.
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENROUTER_TEXT_MODEL=openai/gpt-4.1-mini
GEMINI_TEXT_MODEL=gemini-3.5-flash

# Image generation model used by generate_post_image.
OPENAI_IMAGE_MODEL=gpt-image-1
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Optional OpenRouter metadata.
OPENROUTER_SITE_URL=https://your-site.example
OPENROUTER_SITE_NAME=Daily Social Post MCP Server

# Use "stdio" for local MCP clients, or "http" for Railway/Render.
MCP_TRANSPORT=http
PORT=3000
